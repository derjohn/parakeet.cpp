#!/bin/sh
# AppImage entrypoint: point the loader at the bundled libstdc++/libgomp and
# hand straight off to parakeet-cli. glibc stays system-provided, so the
# AppImage needs a glibc at least as new as the build base's.
HERE=$(dirname "$(readlink -f "$0")")
export LD_LIBRARY_PATH="${HERE}/usr/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
exec "${HERE}/usr/bin/parakeet-cli" "$@"
